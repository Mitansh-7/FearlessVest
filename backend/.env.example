# Fearlessvest Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.

# Get your free Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your free Finnhub API key at: https://finnhub.io/register (100 req/min free)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional: change the port the Flask server runs on (default: 5000)
# PORT=5000